<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="675" viewBox="0 0 1200 675">
  <!-- Background -->
  <rect width="1200" height="675" fill="#f9fafb"/>

  <!-- Card -->
  <rect x="50" y="50" width="1100" height="575" rx="16" fill="white" stroke="#e5e7eb"/>

  <!-- Title -->
  <text x="80" y="95" font-size="22" font-weight="bold" fill="#1f2937">Cookie 池管理</text>
  <text x="900" y="95" font-size="14" fill="#6b7280">共 3 个 Cookie</text>

  <rect x="1000" y="75" width="120" height="35" rx="8" fill="#3b82f6"/>
  <text x="1060" y="98" font-size="13" font-weight="500" text-anchor="middle" fill="white">+ 添加 Cookie</text>

  <!-- Cookie Item 1 -->
  <rect x="80" y="130" width="1040" height="130" rx="12" fill="#f0fdf4" stroke="#86efac"/>

  <circle cx="110" cy="160" r="6" fill="#10b981"/>
  <text x="130" y="165" font-size="16" font-weight="600" fill="#1f2937">Cookie #1</text>
  <text x="250" y="165" font-size="13" fill="#6b7280">并发: 2</text>

  <text x="130" y="190" font-size="12" fill="#6b7280">Token: abc123...</text>
  <text x="130" y="210" font-size="12" fill="#6b7280">LID: xyz789</text>

  <text x="400" y="210" font-size="13" fill="#6b7280">总请求: 1,234</text>
  <text x="550" y="210" font-size="13" fill="#10b981">成功: 1,210</text>
  <text x="680" y="210" font-size="13" fill="#ef4444">错误: 24</text>
  <text x="800" y="210" font-size="13" fill="#6b7280">成功率: 98.1%</text>

  <rect x="1000" y="180" width="80" height="30" rx="6" fill="#fee2e2"/>
  <text x="1040" y="201" font-size="12" text-anchor="middle" fill="#ef4444">删除</text>

  <!-- Cookie Item 2 -->
  <rect x="80" y="280" width="1040" height="130" rx="12" fill="#ecfdf5" stroke="#86efac"/>

  <circle cx="110" cy="310" r="6" fill="#10b981"/>
  <text x="130" y="315" font-size="16" font-weight="600" fill="#1f2937">Cookie #2</text>
  <text x="250" y="315" font-size="13" fill="#6b7280">并发: 1</text>

  <text x="130" y="340" font-size="12" fill="#6b7280">Token: def456...</text>
  <text x="130" y="360" font-size="12" fill="#6b7280">LID: abc123</text>

  <text x="400" y="360" font-size="13" fill="#6b7280">总请求: 856</text>
  <text x="550" y="360" font-size="13" fill="#10b981">成功: 845</text>
  <text x="680" y="360" font-size="13" fill="#ef4444">错误: 11</text>
  <text x="800" y="360" font-size="13" fill="#6b7280">成功率: 98.7%</text>

  <rect x="1000" y="330" width="80" height="30" rx="6" fill="#fee2e2"/>
  <text x="1040" y="351" font-size="12" text-anchor="middle" fill="#ef4444">删除</text>

  <!-- Cookie Item 3 -->
  <rect x="80" y="430" width="1040" height="130" rx="12" fill="#f9fafb" stroke="#e5e7eb"/>

  <circle cx="110" cy="460" r="6" fill="#9ca3af"/>
  <text x="130" y="465" font-size="16" font-weight="600" fill="#1f2937">Cookie #3</text>
  <text x="250" y="465" font-size="13" fill="#6b7280">并发: 0</text>
  <text x="350" y="465" font-size="12" fill="#ef4444">● 已禁用</text>

  <text x="130" y="490" font-size="12" fill="#6b7280">Token: ghi789...</text>
  <text x="130" y="510" font-size="12" fill="#6b7280">LID: def456</text>

  <text x="400" y="510" font-size="13" fill="#6b7280">总请求: 523</text>
  <text x="550" y="510" font-size="13" fill="#10b981">成功: 510</text>
  <text x="680" y="510" font-size="13" fill="#ef4444">错误: 13</text>
  <text x="800" y="510" font-size="13" fill="#6b7280">成功率: 97.5%</text>

  <rect x="1000" y="480" width="80" height="30" rx="6" fill="#fee2e2"/>
  <text x="1040" y="501" font-size="12" text-anchor="middle" fill="#ef4444">删除</text>
</svg>
