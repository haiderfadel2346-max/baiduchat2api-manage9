<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="675" viewBox="0 0 1200 675">
  <!-- Background -->
  <rect width="1200" height="675" fill="#f9fafb"/>

  <!-- Card -->
  <rect x="50" y="50" width="1100" height="575" rx="16" fill="white" stroke="#e5e7eb"/>

  <!-- Tabs -->
  <rect x="80" y="80" width="140" height="40" rx="8" fill="#3b82f6"/>
  <text x="150" y="107" font-size="14" font-weight="500" text-anchor="middle" fill="white">📝 API 日志</text>

  <rect x="230" y="80" width="160" height="40" rx="8" fill="#f3f4f6"/>
  <text x="310" y="107" font-size="14" font-weight="500" text-anchor="middle" fill="#6b7280">🖥️ 系统日志</text>

  <!-- Table Header -->
  <rect x="80" y="150" width="1040" height="40" fill="#f9fafb"/>
  <text x="100" y="175" font-size="12" font-weight="600" fill="#6b7280">时间</text>
  <text x="280" y="175" font-size="12" font-weight="600" fill="#6b7280">端点</text>
  <text x="520" y="175" font-size="12" font-weight="600" fill="#6b7280">模型</text>
  <text x="760" y="175" font-size="12" font-weight="600" fill="#6b7280">状态码</text>
  <text x="900" y="175" font-size="12" font-weight="600" fill="#6b7280">响应时间</text>

  <!-- Table Rows -->
  <!-- Row 1 -->
  <rect x="80" y="190" width="1040" height="50" fill="white" stroke="#e5e7eb"/>
  <text x="100" y="220" font-size="12" fill="#1f2937">14:30:25</text>
  <text x="280" y="220" font-size="11" font-family="monospace" fill="#6b7280">POST /v1/chat/completions</text>
  <text x="520" y="220" font-size="12" fill="#1f2937">baidu-ernie-4.5</text>
  <text x="760" y="220" font-size="12" font-weight="600" fill="#10b981">200</text>
  <text x="900" y="220" font-size="12" fill="#1f2937">350ms</text>

  <!-- Row 2 -->
  <rect x="80" y="240" width="1040" height="50" fill="#f9fafb"/>
  <text x="100" y="270" font-size="12" fill="#1f2937">14:29:18</text>
  <text x="280" y="270" font-size="11" font-family="monospace" fill="#6b7280">POST /v1/chat/completions</text>
  <text x="520" y="270" font-size="12" fill="#1f2937">baidu-deepseek-v4-pro</text>
  <text x="760" y="270" font-size="12" font-weight="600" fill="#10b981">200</text>
  <text x="900" y="270" font-size="12" fill="#1f2937">425ms</text>

  <!-- Row 3 -->
  <rect x="80" y="290" width="1040" height="50" fill="white" stroke="#e5e7eb"/>
  <text x="100" y="320" font-size="12" fill="#1f2937">14:28:05</text>
  <text x="280" y="320" font-size="11" font-family="monospace" fill="#6b7280">GET /v1/models</text>
  <text x="520" y="320" font-size="12" fill="#6b7280">-</text>
  <text x="760" y="320" font-size="12" font-weight="600" fill="#10b981">200</text>
  <text x="900" y="320" font-size="12" fill="#1f2937">45ms</text>

  <!-- Row 4 -->
  <rect x="80" y="340" width="1040" height="50" fill="#f9fafb"/>
  <text x="100" y="370" font-size="12" fill="#1f2937">14:27:32</text>
  <text x="280" y="370" font-size="11" font-family="monospace" fill="#6b7280">POST /v1/chat/completions</text>
  <text x="520" y="370" font-size="12" fill="#1f2937">baidu-ernie-4.5</text>
  <text x="760" y="370" font-size="12" font-weight="600" fill="#ef4444">400</text>
  <text x="900" y="370" font-size="12" fill="#1f2937">120ms</text>

  <!-- Row 5 -->
  <rect x="80" y="390" width="1040" height="50" fill="white" stroke="#e5e7eb"/>
  <text x="100" y="420" font-size="12" fill="#1f2937">14:25:10</text>
  <text x="280" y="420" font-size="11" font-family="monospace" fill="#6b7280">POST /v1/chat/completions</text>
  <text x="520" y="420" font-size="12" fill="#1f2937">baidu-deepseek-r1</text>
  <text x="760" y="420" font-size="12" font-weight="600" fill="#10b981">200</text>
  <text x="900" y="420" font-size="12" fill="#1f2937">580ms</text>

  <!-- Pagination -->
  <rect x="400" y="550" width="100" height="35" rx="8" fill="#f3f4f6"/>
  <text x="450" y="573" font-size="13" text-anchor="middle" fill="#6b7280">上一页</text>

  <text x="600" y="573" font-size="13" text-anchor="middle" fill="#1f2937">第 1 页，共 10 页</text>

  <rect x="700" y="550" width="100" height="35" rx="8" fill="#3b82f6"/>
  <text x="750" y="573" font-size="13" text-anchor="middle" fill="white">下一页</text>
</svg>
