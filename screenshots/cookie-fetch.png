<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="675" viewBox="0 0 1200 675">
  <defs>
    <linearGradient id="blueGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6366f1;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="675" fill="#f9fafb"/>

  <!-- Main Card -->
  <rect x="50" y="50" width="1100" height="575" rx="16" fill="white" stroke="#e5e7eb"/>

  <!-- Header -->
  <text x="80" y="95" font-size="22" font-weight="bold" fill="#1f2937">🍪 Cookie 管理</text>

  <!-- Auto Fetch Section -->
  <rect x="80" y="120" width="1040" height="200" rx="12" fill="#eff6ff" stroke="#bfdbfe"/>

  <text x="110" y="160" font-size="18" font-weight="600" fill="#1f2937">🚀 自动获取 Cookie</text>
  <text x="110" y="185" font-size="13" fill="#6b7280">自动访问百度文心助手并提取 Cookie 信息</text>

  <!-- Auto Fetch Button -->
  <rect x="110" y="210" width="1000" height="50" rx="8" fill="url(#blueGrad)"/>
  <text x="610" y="242" font-size="16" font-weight="500" text-anchor="middle" fill="white">🔄 一键获取 Cookie</text>

  <text x="110" y="290" font-size="12" fill="#6b7280">⚡ 点击按钮，系统将自动提取 token 和 lid 并保存到数据库</text>

  <!-- Current Cookie Status -->
  <rect x="80" y="340" width="1040" height="240" rx="12" fill="white" stroke="#e5e7eb"/>

  <text x="110" y="380" font-size="18" font-weight="600" fill="#1f2937">当前 Cookie 状态</text>

  <circle cx="130" cy="425" r="8" fill="#10b981"/>
  <text x="155" y="432" font-size="15" font-weight="500" fill="#1f2937">✅ Cookie 有效</text>
  <text x="155" y="455" font-size="13" fill="#6b7280">最后更新: 2024-01-10 15:45:30</text>

  <!-- Token Display -->
  <rect x="110" y="480" width="480" height="70" rx="8" fill="#f9fafb"/>
  <text x="130" y="505" font-size="12" fill="#6b7280">Token</text>
  <text x="130" y="530" font-size="13" font-family="monospace" fill="#1f2937">abc123def456ghi789...</text>

  <!-- LID Display -->
  <rect x="610" y="480" width="480" height="70" rx="8" fill="#f9fafb"/>
  <text x="630" y="505" font-size="12" fill="#6b7280">LID</text>
  <text x="630" y="530" font-size="13" font-family="monospace" fill="#1f2937">xyz789abc456</text>
</svg>
